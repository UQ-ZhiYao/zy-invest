# ============================================================
# ZY-Invest Backend — Environment Variables
# Copy this file to .env for local dev (never commit .env)
# Set these in Render.com dashboard for production
# ============================================================

# PostgreSQL (Supabase)
# Find in: Supabase → Project Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT].supabase.co:5432/postgres

# JWT Secret — generate a strong random string
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-random-string

# Frontend URL (your GitHub Pages URL)
# Format: https://[username].github.io/[repo-name]
FRONTEND_URL=https://yourusername.github.io/zy-invest

# Environment
ENV=development   # change to 'production' on Render

# Supabase (for Storage — document uploads)
SUPABASE_URL=https://[YOUR-PROJECT].supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Optional: Scheduler timezone
TZ=Asia/Kuala_Lumpur
